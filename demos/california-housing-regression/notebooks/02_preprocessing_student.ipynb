    "### Step 5. Handle Outliers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b3209031-e7bc-4864-acd2-9c93ee51fddf",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "X_train before capping - Max: 99.00\n",
      "X_train after capping - Max: 52.50\n"
     ]
    }
   ],
   "source": [
    "# Cap outliers at  bound\n",
    "X_train_clean = X_train.copy()\n",
    "X_test_clean = X_test.copy()\n",
    "\n",
    "column = 'hours-per-week'\n",
    "\n",
    "Q1 = X_train_clean[column].quantile(0.25)\n",
    "Q3 = X_train_clean[column].quantile(0.75)\n",
    "IQR = Q3 - Q1\n",
    "lower_bound = Q1 - 1.5*IQR\n",
    "upper_bound = Q3 + 1.5*IQR\n",
    "\n",
    "X_train_clean['hours-per-week_capped'] = X_train_clean['hours-per-week'].clip(lower=lower_bound,upper=upper_bound)\n",
    "\n",
    "print(f\"X_train before capping - Max: {X_train_clean['hours-per-week'].max():.2f}\")\n",
    "print(f\"X_train after capping - Max: {X_train_clean['hours-per-week_capped'].max():.2f}\")"
   ]
  },
  {
   "cell_type": "code",
